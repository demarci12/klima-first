---
import BaseLayout from "./BaseLayout.astro";
import Breadcrumb from "../components/Breadcrumb.astro";

const { title, description, canonical, schema, frontmatter } = Astro.props;

const breadcrumbs = [
  { name: "Főoldal", url: "/" },
  { name: "Tudástár", url: "/tudastar" },
  { name: frontmatter.title, url: Astro.url.pathname },
];
---

<BaseLayout title={title} description={description} canonical={canonical} schema={schema} isArticle>
  <div class="space-y-8">
    <Breadcrumb items={breadcrumbs} />

    <article class="prose prose-slate max-w-none">
      <h1>{frontmatter.title}</h1>
      <p class="text-sm text-slate-600">
        {new Date(frontmatter.pubDate).toLocaleDateString("hu-HU")} • {frontmatter.author}
      </p>
      <slot />
    </article>
  </div>
</BaseLayout>
