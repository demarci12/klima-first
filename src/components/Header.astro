---
---

<header class="sticky top-0 z-40 border-b border-slate-200 bg-white/80 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
    <a href="/" class="flex items-center gap-3 font-bold text-slate-900">
      <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-primary text-white">
        KF
      </span>
      <span class="text-lg">KlimaFirst</span>
    </a>

    <nav class="hidden items-center gap-6 text-sm font-medium text-slate-700 md:flex">
      <a href="/szolgaltatasok/klima-telepites" class="hover:text-primary">Szolgáltatások</a>
      <a href="/arak" class="hover:text-primary">Árak</a>
      <a href="/referenciak" class="hover:text-primary">Referenciák</a>
      <a href="/tudastar" class="hover:text-primary">Tudástár</a>
      <a href="/kapcsolat" class="hover:text-primary">Kapcsolat</a>
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="tel:+36203394164"
        class="hidden items-center gap-2 rounded-full bg-secondary px-4 py-2 text-xs font-semibold text-white shadow-sm transition hover:bg-orange-500 md:inline-flex"
      >
        <span class="text-sm">+36 20 339 4164</span>
      </a>

      <button
        id="mobile-nav-toggle"
        class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-700 shadow-sm md:hidden"
        type="button"
      >
        Menü
      </button>
    </div>
  </div>

  <div id="mobile-nav" class="hidden border-t border-slate-200 bg-white md:hidden">
    <div class="space-y-1 px-4 pb-4 pt-3">
      <a href="/szolgaltatasok/klima-telepites" class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">
        Szolgáltatások
      </a>
      <a href="/arak" class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Árak</a>
      <a href="/referenciak" class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Referenciák</a>
      <a href="/tudastar" class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Tudástár</a>
      <a href="/kapcsolat" class="block rounded-lg px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Kapcsolat</a>
      <a href="tel:+36203394164" class="block rounded-lg bg-secondary px-3 py-2 text-center text-sm font-semibold text-white hover:bg-orange-500">
        +36 20 339 4164
      </a>
    </div>
  </div>

  <script>
    const toggleButton = document.getElementById("mobile-nav-toggle");
    const mobileNav = document.getElementById("mobile-nav");

    toggleButton?.addEventListener("click", () => {
      mobileNav?.classList.toggle("hidden");
    });
  </script>
</header>
