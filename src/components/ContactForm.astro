---
---

<form
  class="grid gap-4 rounded-xl border border-slate-200 bg-white p-6 shadow-sm"
  action="#"
  method="post"
>
  <input type="hidden" name="form-name" value="ajanlat" />
  <div class="sr-only">
    <label for="company">Company</label>
    <input id="company" name="company" type="text" autocomplete="off" />
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <label class="block text-sm font-medium text-slate-700">
      Teljes név*
      <input
        name="name"
        type="text"
        required
        class="mt-1 block w-full rounded border border-slate-200 bg-white px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
      />
    </label>

    <label class="block text-sm font-medium text-slate-700">
      Telefonszám*
      <input
        name="phone"
        type="tel"
        required
        class="mt-1 block w-full rounded border border-slate-200 bg-white px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
      />
    </label>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <label class="block text-sm font-medium text-slate-700">
      E-mail
      <input
        name="email"
        type="email"
        class="mt-1 block w-full rounded border border-slate-200 bg-white px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
      />
    </label>

    <label class="block text-sm font-medium text-slate-700">
      Ingatlan mérete (m²)
      <input
        name="size"
        type="text"
        placeholder="pl. 35"
        class="mt-1 block w-full rounded border border-slate-200 bg-white px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
      />
    </label>
  </div>

  <label class="block text-sm font-medium text-slate-700">
    Üzenet
    <textarea
      name="message"
      rows="4"
      class="mt-1 block w-full resize-none rounded border border-slate-200 bg-white px-3 py-2 text-sm shadow-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/30"
    ></textarea>
  </label>

  <button
    type="submit"
    class="w-full rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-800"
  >
    Ajánlatkérés elküldése
  </button>
</form>
