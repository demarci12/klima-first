---
const { title, description, href, icon } = Astro.props;
---

<article class="group rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
  <div class="flex items-start gap-4">
    <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary">
      {icon ?? "⚡"}
    </div>
    <div>
      <h3 class="text-lg font-semibold text-slate-900">{title}</h3>
      <p class="mt-2 text-sm text-slate-600">{description}</p>
    </div>
  </div>

  <a
    href={href}
    class="mt-6 inline-flex items-center gap-2 text-sm font-semibold text-primary hover:text-primary/80"
  >
    Bővebben
    <span aria-hidden="true">→</span>
  </a>
</article>
