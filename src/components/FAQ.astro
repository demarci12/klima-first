---
const { items = [] } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: items.map((item) => ({
    "@type": "Question",
    name: item.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer,
    },
  })),
};
---

<section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
  <h2 class="text-xl font-semibold text-slate-900">Gyakran Ismételt Kérdések</h2>
  <div class="mt-6 space-y-4">
    {items.map((item) => (
      <details class="rounded-xl border border-slate-200 bg-slate-50 p-4" key={item.question}>
        <summary class="cursor-pointer font-medium text-slate-900">{item.question}</summary>
        <p class="mt-2 text-sm text-slate-700">{item.answer}</p>
      </details>
    ))}
  </div>

  <script type="application/ld+json" dangerouslySetInnerHTML={{ __html: JSON.stringify(schema) }} />
</section>
