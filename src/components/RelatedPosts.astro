---
import { getCollection } from "astro:content";

const { tags = [], currentSlug } = Astro.props;

const allPosts = await getCollection("tudastar");

const related = allPosts
  .filter((post) => post.slug !== currentSlug)
  .filter((post) => post.data.tags?.some((tag) => tags.includes(tag)))
  .slice(0, 3);
---

{related.length > 0 ? (
  <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-xl font-semibold text-slate-900">Kapcsolódó cikkek</h2>
    <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {related.map((post) => (
        <a
          key={post.slug}
          href={`/tudastar/${post.slug}`}
          class="rounded-2xl border border-slate-200 bg-slate-50 p-5 transition hover:border-primary hover:bg-white"
        >
          <p class="text-sm font-semibold text-slate-900">{post.data.title}</p>
          <p class="mt-2 text-xs text-slate-600">{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
) : null}
