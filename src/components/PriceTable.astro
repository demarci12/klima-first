---
const { items = [] } = Astro.props;
---

<div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
  <table class="w-full border-collapse text-left text-sm">
    <thead class="bg-slate-50">
      <tr>
        <th class="px-4 py-3 font-semibold text-slate-700">Szolgáltatás</th>
        <th class="px-4 py-3 font-semibold text-slate-700">Ár</th>
        <th class="px-4 py-3 font-semibold text-slate-700">Megjegyzés</th>
      </tr>
    </thead>
    <tbody>
      {items.map((item, index) => (
        <tr class={index % 2 === 0 ? "bg-white" : "bg-slate-50"} key={item.name}>
          <td class="px-4 py-3">{item.name}</td>
          <td class="px-4 py-3 font-semibold text-slate-900">{item.price.toLocaleString()} {item.currency}</td>
          <td class="px-4 py-3 text-slate-600">{item.description}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
