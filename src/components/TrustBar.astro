---
const { items = [] } = Astro.props;
---

<div class="grid grid-cols-1 gap-4 rounded-2xl border border-slate-200 bg-white p-6 shadow-sm sm:grid-cols-2 lg:grid-cols-4">
  {items.map((item) => (
    <div class="flex items-start gap-3" key={item.label}>
      <div class="mt-1 flex h-10 w-10 items-center justify-center rounded-lg bg-primary/10 text-primary">
        {item.icon || "✓"}
      </div>
      <div>
        <p class="text-sm font-semibold text-slate-900">{item.label}</p>
        <p class="text-sm text-slate-600">{item.value}</p>
      </div>
    </div>
  ))}
</div>
