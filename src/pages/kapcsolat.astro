---
import BaseLayout from "../layouts/BaseLayout.astro";
import ContactForm from "../components/ContactForm.astro";

const title = "Kapcsolat | KlimaFirst";
const description = "Lépjen kapcsolatba velünk klímaszerelés ügyében Budapesten.";
---

<BaseLayout title={title} description={description} canonical="https://klimafirst.hu/kapcsolat">
  <article class="space-y-8">
    <header>
      <h1 class="text-3xl font-bold text-slate-900">Kapcsolat</h1>
      <p class="mt-3 text-sm text-slate-600">
        Kérjen ingyenes helyszíni felmérést vagy érdeklődjön szolgáltatásainkról.
      </p>
    </header>

    <div class="grid gap-8 lg:grid-cols-2">
      <div class="space-y-6">
        <section class="space-y-4">
          <h2 class="text-xl font-semibold text-slate-900">Elérhetőségeink</h2>
          <div class="space-y-3 text-sm">
            <p><strong>Telefon:</strong> <a href="tel:+36203394164" class="text-primary hover:underline">+36 20 339 4164</a></p>
            <p><strong>E-mail:</strong> <a href="mailto:info@klimafirst.hu" class="text-primary hover:underline">info@klimafirst.hu</a></p>
            <p><strong>Cég:</strong> Juhász Solutions Kft.</p>
            <p><strong>Szolgáltatási terület:</strong> Budapest és környéke</p>
          </div>
        </section>

        <section class="space-y-4">
          <h2 class="text-xl font-semibold text-slate-900">Ügyfélfogadás</h2>
          <div class="space-y-2 text-sm text-slate-600">
            <p>Hétfő – Péntek: 8:00 – 18:00</p>
            <p>Szombat: 9:00 – 14:00</p>
            <p>Vasárnap: Zárva</p>
          </div>
        </section>
      </div>

      <ContactForm />
    </div>
  </article>
</BaseLayout>
