---
import { keruletek } from "../../data/keruletek";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";

export async function getStaticPaths() {
  return keruletek.map((kerulet) => ({
    params: { kerulet: kerulet.slug },
    props: { kerulet },
  }));
}

const { kerulet } = Astro.props;

const title = `Klímaszerelés Budapest ${kerulet.name} | KlimaFirst`;
const description = `Klíma telepítés, javítás és karbantartás Budapest ${kerulet.name} területén. Ingyenes felmérés és kiszállás.`;

const schema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: `KlimaFirst – Klímaszerelés Budapest ${kerulet.name}`,
  url: `https://klimafirst.hu/budapest/${kerulet.slug}`,
  telephone: "+36-20-339-4164",
  areaServed: {
    "@type": "AdministrativeArea",
    name: `Budapest ${kerulet.name}`,
    containedInPlace: { "@type": "City", name: "Budapest" },
  },
};

const breadcrumbs = [
  { name: "Főoldal", url: "/" },
  { name: "Budapest", url: "/budapest" },
  { name: kerulet.name, url: `/budapest/${kerulet.slug}` },
];
---

<BaseLayout title={title} description={description} canonical={`https://klimafirst.hu/budapest/${kerulet.slug}`} schema={schema}>
  <div class="space-y-8">
    <Breadcrumb items={breadcrumbs} />

    <article class="space-y-6">
      <header>
        <h1 class="text-3xl font-bold text-slate-900">Klímaszerelés Budapest {kerulet.name}</h1>
        <p class="mt-3 text-sm text-slate-600">
          Klíma telepítés, javítás és karbantartás Budapest {kerulet.name} területén. {kerulet.description}
        </p>
      </header>

      <section class="space-y-4">
        <h2 class="text-xl font-semibold text-slate-900">Szolgáltatásaink {kerulet.name}-ban</h2>
        <ul class="list-inside list-disc space-y-2 text-sm text-slate-600">
          <li>Klíma telepítés és értékesítés</li>
          <li>Klíma javítás és szerviz</li>
          <li>Klíma tisztítás és karbantartás</li>
          <li>Fűtés klímával</li>
        </ul>
      </section>

      <section class="space-y-4">
        <h2 class="text-xl font-semibold text-slate-900">Miért minket válasszon {kerulet.name}-ban?</h2>
        <p class="text-sm text-slate-600">
          Ingyenes helyszíni felmérés, gyors kiszállás és személyre szabott megoldások. Budapest {kerulet.name} területén is elérhetőek szolgáltatásaink.
        </p>
      </section>

      <div class="flex flex-wrap gap-4">
        <a
          href="/ajanlatkeres"
          class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-800"
        >
          Ingyenes Ajánlatkérés
        </a>
        <a
          href="tel:+36203394164"
          class="inline-flex items-center justify-center rounded-full border border-slate-200 bg-white px-6 py-3 text-sm font-semibold text-slate-900 shadow-sm transition hover:bg-slate-50"
        >
          +36 20 339 4164
        </a>
      </div>
    </article>
  </div>
</BaseLayout>
