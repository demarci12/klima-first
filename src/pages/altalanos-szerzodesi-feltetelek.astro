---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Általános Szerződési Feltételek | KlimaFirst";
const description = "Általános szerződési feltételeink.";
---

<BaseLayout title={title} description={description} canonical="https://klimafirst.hu/altalanos-szerzodesi-feltetelek">
  <article class="space-y-8">
    <header>
      <h1 class="text-3xl font-bold text-slate-900">Általános Szerződési Feltételek</h1>
      <p class="mt-3 text-sm text-slate-600">
        Általános szerződési feltételeink.
      </p>
    </header>

    <section class="prose prose-slate max-w-none">
      <p>Ez az oldal tartalmazza általános szerződési feltételeinket.</p>
      <!-- Placeholder content -->
    </section>
  </article>
</BaseLayout>
