---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Referenciák | KlimaFirst";
const description =
  "KlimaFirst referenciák – több mint 5000 elégedett ügyfél Budapesten. Nézze meg munkáinkat!";
---

<BaseLayout title={title} description={description} canonical="https://klimafirst.hu/referenciak">
  <article class="space-y-8">
    <header>
      <h1 class="text-3xl font-bold text-slate-900">Referenciák</h1>
      <p class="mt-3 text-sm text-slate-600">
        Több mint 5000 elégedett ügyfél Budapesten. Nézze meg munkáinkat és ügyfeleink véleményeit.
      </p>
    </header>

    <section class="space-y-6">
      <h2 class="text-2xl font-semibold text-slate-900">Ügyfeleink mondták</h2>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <p class="text-sm text-slate-600">
            "Gyors és precíz munka. A klíma telepítése után azonnal működött, és azóta sem volt vele gond."
          </p>
          <p class="mt-3 text-xs font-semibold text-slate-900">– Kovács István, XIII. kerület</p>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <p class="text-sm text-slate-600">
            "Ingyenes felmérés és kedvező ár. A szerelők nagyon szakértők voltak."
          </p>
          <p class="mt-3 text-xs font-semibold text-slate-900">– Nagy Anna, II. kerület</p>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <p class="text-sm text-slate-600">
            "Karbantartás után sokkal hatékonyabban működik a klíma. Ajánlom mindenkinek."
          </p>
          <p class="mt-3 text-xs font-semibold text-slate-900">– Szabó László, XI. kerület</p>
        </div>
      </div>
    </section>

    <section class="space-y-6">
      <h2 class="text-2xl font-semibold text-slate-900">Elvégzett munkák</h2>
      <div class="grid gap-6 md:grid-cols-2">
        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="text-lg font-semibold text-slate-900">Lakás klíma telepítés</h3>
          <p class="mt-2 text-sm text-slate-600">35 m²-es nappali, Fisher klíma, XIII. kerület.</p>
        </div>

        <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <h3 class="text-lg font-semibold text-slate-900">Iroda klíma javítás</h3>
          <p class="mt-2 text-sm text-slate-600">Hűtési rendszer javítása, Fujitsu klíma, V. kerület.</p>
        </div>
      </div>
    </section>
  </article>
</BaseLayout>
