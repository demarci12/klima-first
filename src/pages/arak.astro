---
import BaseLayout from "../layouts/BaseLayout.astro";
import PriceTable from "../components/PriceTable.astro";
import { pricing } from "../data/pricing";

const title = "Klímaszerelés Árak Budapest 2025 | KlimaFirst";
const description =
  "Klímaszerelés árak Budapesten 2025-ben. Nettó 75 000 Ft-tól. Mit tartalmaz az ár? Ingyenes felmérés és kiszállás.";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Klímaszerelés Budapest",
  offers: pricing.map((item) => ({
    "@type": "Offer",
    name: item.name,
    price: item.price.toString(),
    priceCurrency: item.currency,
    description: item.description,
  })),
};
---

<BaseLayout title={title} description={description} canonical="https://klimafirst.hu/arak" schema={schema}>
  <article class="space-y-8">
    <header>
      <h1 class="text-3xl font-bold text-slate-900">Klímaszerelés Árak Budapest 2025</h1>
      <p class="mt-3 text-sm text-slate-600">
        Klímaszerelés árak Budapesten – nettó 75 000 Ft-tól. Ingyenes felmérés és kiszállás.
      </p>
    </header>

    <section class="space-y-6">
      <h2 class="text-2xl font-semibold text-slate-900">Árképzés</h2>
      <p class="text-sm text-slate-600">
        Az alábbi árak irányárak, amelyek a telepített beltéri egység számától és a helyszíni adottságoktól függően változhatnak.
      </p>

      <PriceTable items={pricing} />

      <div class="grid gap-6 lg:grid-cols-2">
        <div class="space-y-3 rounded-2xl border border-slate-200 bg-slate-50 p-6">
          <h3 class="text-lg font-semibold text-slate-900">Mit tartalmaz az ár?</h3>
          <ul class="list-inside list-disc space-y-2 text-sm text-slate-600">
            <li>Kiszállás és helyszíni felmérés Budapesten.</li>
            <li>Anyagköltség (rézcső, tömítések, rögzítések).</li>
            <li>Beüzemelés és rendszeres működés ellenőrzése.</li>
            <li>1 év garancia a munkára.</li>
          </ul>
        </div>

        <div class="space-y-3 rounded-2xl border border-slate-200 bg-slate-50 p-6">
          <h3 class="text-lg font-semibold text-slate-900">Mit NEM tartalmaz az ár?</h3>
          <ul class="list-inside list-disc space-y-2 text-sm text-slate-600">
            <li>Extra rézcső több mint 2 fm esetén (12 500 Ft + ÁFA/fm).</li>
            <li>Falhorony készítés (20 000 Ft + ÁFA/fm).</li>
            <li>Kondenzvíz külön nyomvonal (2 500 Ft + ÁFA/fm).</li>
            <li>Készülék ára (150 000 – 600 000 Ft + ÁFA a típustól függően).</li>
          </ul>
        </div>
      </div>

      <section class="space-y-4">
        <h2 class="text-2xl font-semibold text-slate-900">Karbantartás ára</h2>
        <p class="text-sm text-slate-600">
          A rendszeres karbantartás meghosszabbítja a klíma élettartamát és javítja a hatékonyságot. Kérje ajánlatunkat.
        </p>
      </section>

      <section class="space-y-4">
        <h2 class="text-2xl font-semibold text-slate-900">Gyakran ismételt kérdések</h2>
        <div class="space-y-4">
          <details class="rounded-xl border border-slate-200 bg-white p-4">
            <summary class="cursor-pointer font-medium text-slate-900">Hogyan számolják az árakat?</summary>
            <p class="mt-2 text-sm text-slate-600">
              Az árakat a helyszíni adottságok, a beltéri és kültéri egység elhelyezése és a szükséges anyagok alapján számoljuk.
            </p>
          </details>
          <details class="rounded-xl border border-slate-200 bg-white p-4">
            <summary class="cursor-pointer font-medium text-slate-900">Mit tegyek, ha specifikus igényeim vannak?</summary>
            <p class="mt-2 text-sm text-slate-600">
              Küldjön részletes leírást ajánlatkérésnél, és a helyszíni felmérés során figyelembe vesszük a külön igényeket.
            </p>
          </details>
        </div>
      </section>
    </section>
  </article>
</BaseLayout>
