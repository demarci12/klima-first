---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Fujitsu Klíma Budapest | KlimaFirst";
const description =
  "Fujitsu klímák Budapesten – magas hatékonyság és modern technológia. Kérjen személyre szabott ajánlatot.";
---

<BaseLayout title={title} description={description} canonical="https://klimafirst.hu/keszulekek/fujitsu-klima">
  <article class="space-y-8">
    <header>
      <h1 class="text-3xl font-bold text-slate-900">Fujitsu Klíma</h1>
      <p class="mt-3 text-sm text-slate-600">
        Fujitsu klímák – prémium minőség és energiatakarékos működés a legújabb technológiával.
      </p>
    </header>

    <section class="space-y-4">
      <h2 class="text-2xl font-semibold text-slate-900">Miért a Fujitsu klíma?</h2>
      <p class="text-sm text-slate-600">
        A Fujitsu klímák kimagasló hatékonyságot és csendes üzemet kínálnak, ideális nagyobb helyiségekhez.
      </p>
      <ul class="list-inside list-disc space-y-2 text-sm text-slate-600">
        <li>Magas SCOP és SEER értékek</li>
        <li>Könnyű kezelhetőség és intelligens vezérlés</li>
        <li>Kényelmes karbantartás és hosszú élettartam</li>
      </ul>
    </section>

    <section class="space-y-4">
      <h2 class="text-2xl font-semibold text-slate-900">Milyen modelleket ajánlunk?</h2>
      <p class="text-sm text-slate-600">(Placeholder listák; a részletes termékleírás hamarosan elérhető.)</p>
    </section>

    <section class="space-y-4">
      <h2 class="text-2xl font-semibold text-slate-900">Miért válassza a Fujitsu klímát?</h2>
      <p class="text-sm text-slate-600">
        Kiemelkedő energiahatékonyság és megbízható működés hosszú távon.
      </p>
    </section>

    <a
      href="/ajanlatkeres"
      class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-800"
    >
      Kérjen ajánlatot
    </a>
  </article>
</BaseLayout>
