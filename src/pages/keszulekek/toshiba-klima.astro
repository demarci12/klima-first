---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Toshiba Klíma Budapest | KlimaFirst";
const description =
  "Toshiba klímák Budapesten – energiahatékony és tartós készülékek professzionális beállítással.";
---

<BaseLayout title={title} description={description} canonical="https://klimafirst.hu/keszulekek/toshiba-klima">
  <article class="space-y-8">
    <header>
      <h1 class="text-3xl font-bold text-slate-900">Toshiba Klíma</h1>
      <p class="mt-3 text-sm text-slate-600">
        Toshiba klímák – energiahatékony és tartós készülékek professzionális beállítással.
      </p>
    </header>

    <section class="space-y-4">
      <h2 class="text-2xl font-semibold text-slate-900">Miért a Toshiba klíma?</h2>
      <p class="text-sm text-slate-600">
        A Toshiba márka hosszú távú megbízhatóságáról és energiahatékonyságáról ismert. Kiváló választás tartósságot és teljesítményt keresőknek.
      </p>
      <ul class="list-inside list-disc space-y-2 text-sm text-slate-600">
        <li>Energiahatékony működés</li>
        <li>Tartós és megbízható konstrukció</li>
        <li>Professzionális beállítási lehetőségek</li>
      </ul>
    </section>

    <section class="space-y-4">
      <h2 class="text-2xl font-semibold text-slate-900">Milyen modelleket ajánlunk?</h2>
      <p class="text-sm text-slate-600">(Helykitöltő lists; részletes modellek hamarosan.)</p>
    </section>

    <section class="space-y-4">
      <h2 class="text-2xl font-semibold text-slate-900">Miért válassza a Toshiba klímát?</h2>
      <p class="text-sm text-slate-600">
        Fókuszban a tartósság, az energiahatékonyság és a professzionális teljesítmény.
      </p>
    </section>

    <section class="space-y-4">
      <h2 class="text-2xl font-semibold text-slate-900">Vélemények</h2>
      <p class="text-sm text-slate-600">(Helykitöltő vélemények és referenciák.)</p>
    </section>

    <a
      href="/ajanlatkeres"
      class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-800"
    >
      Kérjen ajánlatot
    </a>
  </article>
</BaseLayout>
