---
import BaseLayout from "../../layouts/BaseLayout.astro";

const title = "Fisher Klíma Budapest | KlimaFirst";
const description =
  "Fisher klímák Budapesten – megbízható teljesítmény és jó ár-érték arány. Kérjen ajánlatot most!";
---

<BaseLayout title={title} description={description} canonical="https://klimafirst.hu/keszulekek/fisher-klima">
  <article class="space-y-8">
    <header>
      <h1 class="text-3xl font-bold text-slate-900">Fisher Klíma</h1>
      <p class="mt-3 text-sm text-slate-600">
        Fisher klímák – megbízható és költséghatékony megoldás otthonába vagy irodájába.
      </p>
    </header>

    <section class="space-y-4">
      <h2 class="text-2xl font-semibold text-slate-900">Miért a Fisher klíma?</h2>
      <p class="text-sm text-slate-600">
        A Fisher márka stabil minőséget kínál kedvező áron. Ideális választás azoknak, akik tartós és hatékony klímát keresnek.
      </p>
      <ul class="list-inside list-disc space-y-2 text-sm text-slate-600">
        <li>Gazdaságos energiafogyasztás</li>
        <li>Egyszerű kezelhetőség</li>
        <li>Kedvező árú karbantartás</li>
      </ul>
    </section>

    <section class="space-y-4">
      <h2 class="text-2xl font-semibold text-slate-900">Milyen modelleket ajánlunk?</h2>
      <p class="text-sm text-slate-600">(Placeholder lists; részletes modellek hamarosan.)</p>
    </section>

    <section class="space-y-4">
      <h2 class="text-2xl font-semibold text-slate-900">Miért válassza a Fisher klímát?</h2>
      <p class="text-sm text-slate-600">
        Fókuszban a megbízhatóság, alacsony üzemeltetési költségek és egyszerű használat.
      </p>
    </section>

    <section class="space-y-4">
      <h2 class="text-2xl font-semibold text-slate-900">Vélemények</h2>
      <p class="text-sm text-slate-600">(Helykitöltő vélemények és referenciák.)</p>
    </section>

    <a
      href="/ajanlatkeres"
      class="inline-flex items-center justify-center rounded-full bg-primary px-6 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-800"
    >
      Kérjen ajánlatot
    </a>
  </article>
</BaseLayout>
