---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Adatvédelmi Irányelvek | KlimaFirst";
const description = "Adatvédelmi irányelveink és adatkezelési tájékoztatónk.";
---

<BaseLayout title={title} description={description} canonical="https://klimafirst.hu/adatvedelmi-iranyelvek">
  <article class="space-y-8">
    <header>
      <h1 class="text-3xl font-bold text-slate-900">Adatvédelmi Irányelvek</h1>
      <p class="mt-3 text-sm text-slate-600">
        Adatvédelmi irányelveink és adatkezelési tájékoztatónk.
      </p>
    </header>

    <section class="prose prose-slate max-w-none">
      <p>Ez az oldal tartalmazza adatvédelmi irányelveinket.</p>
      <!-- Placeholder content -->
    </section>
  </article>
</BaseLayout>
