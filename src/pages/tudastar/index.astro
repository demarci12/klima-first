---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = await getCollection("tudastar");

const title = "Tudástár | Klíma Tippek és Tanácsok | KlimaFirst";
const description = "Klíma telepítés, karbantartás és használat tippek Budapesten. Olvassa el szakértői tanácsainkat.";
---

<BaseLayout title={title} description={description} canonical="https://klimafirst.hu/tudastar">
  <article class="space-y-8">
    <header>
      <h1 class="text-3xl font-bold text-slate-900">Tudástár</h1>
      <p class="mt-3 text-sm text-slate-600">
        Klíma telepítés, karbantartás és használat tippek szakértőinktől.
      </p>
    </header>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <a
          key={post.slug}
          href={`/tudastar/${post.slug}`}
          class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-primary hover:bg-slate-50"
        >
          <h2 class="text-lg font-semibold text-slate-900">{post.data.title}</h2>
          <p class="mt-2 text-sm text-slate-600">{post.data.description}</p>
          <p class="mt-4 text-xs text-slate-500">
            {new Date(post.data.pubDate).toLocaleDateString("hu-HU")}
          </p>
        </a>
      ))}
    </div>
  </article>
</BaseLayout>
