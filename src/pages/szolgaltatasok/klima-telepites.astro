---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FAQ from "../../components/FAQ.astro";
import { faq } from "../../data/faq";

const title = "Klíma Telepítés és Értékesítés Budapest | KlimaFirst";
const description =
  "Ingyenes helyszíni felmérés, precíz szerelés és saját magyarázó árak klíma telepítésre Budapesten.";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: "Klíma telepítés",
  serviceType: "HVAC Installation",
  provider: { "@type": "LocalBusiness", name: "KlimaFirst", url: "https://klimafirst.hu" },
  areaServed: { "@type": "City", name: "Budapest" },
  description,
  aggregateRating: { "@type": "AggregateRating", ratingValue: "4.9", reviewCount: "87" },
  offers: { "@type": "Offer", priceCurrency: "HUF", price: "75000", priceSpecification: { "@type": "UnitPriceSpecification", priceCurrency: "HUF", unitText: "beltéri egység" } },
};
---

<BaseLayout title={title} description={description} canonical="https://klimafirst.hu/szolgaltatasok/klima-telepites" schema={schema}>
  <article class="space-y-8">
    <header>
      <h1 class="text-3xl font-bold text-slate-900">Klíma Telepítés és Értékesítés Budapest</h1>
      <p class="mt-3 text-sm text-slate-600">
        Ingyenes helyszíni felmérés, kiszállás díj nélkül Budapesten, és személyre szabott telepítési ajánlat.
      </p>
    </header>

    <section class="grid gap-6 lg:grid-cols-2">
      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-slate-900">Miért érdemes minket választani?</h2>
        <ul class="list-inside list-disc space-y-2 text-sm text-slate-600">
          <li>Gyors felmérés, részletes ajánlat készítése.</li>
          <li>Szakmai tanácsadás a készülék kiválasztásához.</li>
          <li>Precíz, esztétikus szerelés és beüzemelés.</li>
          <li>Garancia a munkára és alkatrészekre.</li>
        </ul>
      </div>

      <div class="space-y-4">
        <h2 class="text-xl font-semibold text-slate-900">Mit tartalmaz az ajánlat?</h2>
        <ul class="list-inside list-disc space-y-2 text-sm text-slate-600">
          <li>Ingyenes helyszíni felmérés Budapesten.</li>
          <li>Telepítés és beüzemelés a helyszínen.</li>
          <li>Rézcső, vezetékek, szigetelés és rögzítések.</li>
          <li>1 év garancia a munkára és a beüzemelésre.</li>
        </ul>
      </div>
    </section>

    <FAQ items={faq.slice(0, 5)} />
  </article>
</BaseLayout>
