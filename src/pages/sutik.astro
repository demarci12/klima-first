---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Sütik | KlimaFirst";
const description = "Süti tájékoztatónk és adatkezelési információk.";
---

<BaseLayout title={title} description={description} canonical="https://klimafirst.hu/sutik">
  <article class="space-y-8">
    <header>
      <h1 class="text-3xl font-bold text-slate-900">Sütik</h1>
      <p class="mt-3 text-sm text-slate-600">
        Süti tájékoztatónk és adatkezelési információk.
      </p>
    </header>

    <section class="prose prose-slate max-w-none">
      <p>Ez az oldal tartalmazza süti tájékoztatónkat.</p>
      <!-- Placeholder content -->
    </section>
  </article>
</BaseLayout>
